# ── Platform: "ado" or "github" ──────────────────────────────────
PLATFORM=ado

# ── LLM ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GPT_MODEL=gpt-4.1

# ── Azure DevOps (required when PLATFORM=ado) ────────────────────
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/YourOrg
AZURE_DEVOPS_DEFAULT_PROJECT=YourProject
AZURE_DEVOPS_PAT=your-pat-token

# ── GitHub (required when PLATFORM=github) ────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo

# ── PR to review ─────────────────────────────────────────────────
PR_ID=12345

# ── Slack (optional, both platforms) ──────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T00000000
SLACK_CHANNEL_IDS=C00000000

# ── Tuning (optional) ────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF=2.0
COMMENT_SCALE_FACTOR=2.0
